{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "taml",
  "scopeName": "source.taml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "match": "\\b(interface|component|extends|implements|import|from)\\b", "name": "keyword.control.taml" },
    { "match": "\\b(String|Int|Float|Boolean)\\b", "name": "support.type.taml" },
    { "match": "\\b(min|max|pattern)\\s*(?=:)", "name": "entity.other.attribute-name.taml" },
    { "match": "\\b(true|false|null)\\b", "name": "constant.language.taml" },
    { "match": "(?<![A-Za-z0-9_-])-?(?:0|[1-9]\\d*)(?:\\.\\d+)?\\b", "name": "constant.numeric.taml" },
    { "match": "\\b[A-Za-z_][A-Za-z0-9_-]*(?=\\??\\s*:)", "name": "variable.other.property.taml" },
    { "match": "[:?=|]", "name": "punctuation.separator.taml" }
  ],
  "repository": {
    "comment": {
      "patterns": [{ "match": "#.*$", "name": "comment.line.number-sign.taml" }]
    },
    "string": {
      "patterns": [
        {
          "begin": "\\\"",
          "end": "\\\"",
          "name": "string.quoted.double.taml",
          "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.taml" }]
        },
        { "begin": "'", "end": "'", "name": "string.quoted.single.taml" }
      ]
    }
  }
}
